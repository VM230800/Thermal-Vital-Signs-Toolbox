    save_roi_overlay,
    save_signal_comparison,
)

# ── Load config ──
with open("configs/run_config.yaml") as f:
    config = yaml.safe_load(f)

with open("configs/bp4d.yaml") as f:
    ds_config = yaml.safe_load(f)

# ── Load dataset ──
